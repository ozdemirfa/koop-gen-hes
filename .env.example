# Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DATABASE_PASSWORD=

# Server
PORT=3001
NODE_ENV=development

# Client (Vite prefix)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Playwright E2E
E2E_USER=
E2E_PASSWORD=

# Public origin (davet linki redirect + e-mail içeriği için)
APP_PUBLIC_URL=

# Transactional mail (Resend) — davet akışı
# Eğer RESEND_API_KEY boş ise mail gönderimleri stub mode (logger'a yazılır)
RESEND_API_KEY=
MAIL_FROM=noreply@koopgenhes.com
